# wiz_pr_pipeline.env — shared config for the Wiz PR-review Slack pipeline.
#
# Sourced by wiz_pr_review.sh and wiz_pr_watch_finalize.sh.
# NOT secret (no tokens) — the Slack bot token is read from ~/.hermes/.env at
# runtime by the watcher.
#
# ----------------------------------------------------------------------------
# MODE / ACTIVE CHANNEL  (managed by wiz_pr_mode.sh — do not hand-edit)
# ----------------------------------------------------------------------------
# WIZ_ACTIVE_CHANNEL is the single channel the pipeline both MONITORS and posts
# ALL output to (threaded). Because the trigger channel and the output channel
# are the SAME, output can never leak into a different channel.
#
#   test mode -> #wiz-bot           (home/ops channel) C0BCCTG5F0R
#   prod mode -> #wiz-pull-requests (PR channel)       C0APAGTP97F
#
# Flip with:  ./wiz_pr_mode.sh test   |   ./wiz_pr_mode.sh prod
# (then restart the gateway so the trigger-channel config takes effect.)
WIZ_TEST_MODE=false
WIZ_ACTIVE_CHANNEL="C0APAGTP97F"

# Stable channel IDs (referenced by wiz_pr_mode.sh).
WIZ_HOME_CHANNEL="C0BCCTG5F0R"      # #wiz-bot
WIZ_PR_CHANNEL="C0APAGTP97F"        # #wiz-pull-requests

# ----------------------------------------------------------------------------
# DEFAULTS
# ----------------------------------------------------------------------------
# Default Maestro agent type when the Slack message doesn't specify one.
WIZ_DEFAULT_AGENT_TYPE="claude-code"

# ----------------------------------------------------------------------------
# GH ACCOUNT PINNING  (pin the pipeline to the bot's GitHub identity)
# ----------------------------------------------------------------------------
# The whole board pipeline needs the `read:project`/`project` scope for GitHub
# Projects v2 (status reads/writes, the board scan). `gh` uses whatever account
# is *active*, and that can silently flip (it did: active switched from
# wiz-maestro -> ksylvan, and ksylvan's token lacks `read:project`, so the board
# poller went blind for ~1h). To make the pipeline immune to the active-account
# state, we pin GH_TOKEN to a specific account's token here — every `gh` call in
# any script that sources this file then uses that token regardless of which
# account `gh auth` considers active.
#
# WIZ_GH_ACCOUNT is the GitHub login whose token we pin (the bot identity).
# Defensive: only set GH_TOKEN if it isn't already set (respect an explicit
# override) and if we can actually retrieve the account's token.
WIZ_GH_ACCOUNT="wiz-maestro"
if [[ -z "${GH_TOKEN:-}" ]] && command -v gh >/dev/null 2>&1; then
    _wiz_gh_token="$(gh auth token --user "$WIZ_GH_ACCOUNT" 2>/dev/null)"
    if [[ -n "$_wiz_gh_token" ]]; then
        export GH_TOKEN="$_wiz_gh_token"
    fi
    unset _wiz_gh_token
fi

# Files uploaded to the thread when a review finishes (relative to AUTORUN_FOLDER).
WIZ_REVIEW_FILES=(REVIEW_SCOPE.md CODE_ISSUES.md SECURITY_ISSUES.md TEST_GAPS.md REVIEW_SUMMARY.md)

# Finalize prompt sent to the Maestro agent after the review completes.
WIZ_FINALIZE_PROMPT="${HOME}/wizard/tmp/prompts/use-gh-cli-to-create-pr-review-from-summary-finalize.md"

# maestro_watch.sh tuning (grace seconds, poll seconds).
WIZ_WATCH_GRACE=90
WIZ_WATCH_POLL=10

# Reaction emoji names (no colons) used to annotate the triggering PR-link
# message: in-progress when the review starts, then swapped to done/failed.
WIZ_REACT_INPROGRESS="hourglass_flowing_sand"
WIZ_REACT_DONE="white_check_mark"
WIZ_REACT_FAILED="x"

# Directory for thread -> PR state records, keyed by Slack thread ts. Written by
# wiz_pr_review.sh on review 1, read back by wiz_pr_rereview.sh so a "re-review"
# reply (which carries no PR link) can recover the repo/PR/agent it belongs to.
WIZ_PR_STATE_DIR="${HOME}/wizard/tmp/wiz-pr-state"

# ----------------------------------------------------------------------------
# BOARD-DRIVEN TRIGGER  (wiz_pr_poll_board.sh — GitHub Projects v2 polling)
# ----------------------------------------------------------------------------
# Carol's model: kick off reviews by SETTING a board status, not by typing in
# Slack; Slack drops to a notification channel. A human sets a PR's Status to
# WIZ_QUEUE_STATUS on org project #1 ("Wizard Development"); the poller picks it
# up, validates eligibility, and (only for eligible PRs) advances it to
# "AI Review 1" and launches the review. This is ADDITIVE — the Slack-link and
# threaded-re-review triggers keep working unchanged.
#
# Invariant: WIZ_QUEUE_STATUS only ever advances to "AI Review N" when a review
# actually launches. Every non-launching outcome routes to a MEANINGFUL resting
# state so the item is not re-processed next tick:
#   - merged/closed PR  -> WIZ_BOARD_CLOSED_STATUS  ("Done")
#   - open + draft PR    -> WIZ_BOARD_CLEAR_STATUS   ("Backlog")
#   - re-review, no new commits -> restored to the true round (AI Review 1/2)
WIZ_QUEUE_STATUS="Queue AI Review"     # the trigger value a human sets
WIZ_BOARD_CLEAR_STATUS="Backlog"       # where ineligible (draft) PRs are parked
WIZ_BOARD_CLOSED_STATUS="Done"         # where merged/closed PRs are parked
WIZ_PROJECT_NUMBER=1                    # org project #1 "Wizard Development"
WIZ_PROJECT_ORG="story-wizard"

# Board-driven TAGGED BUILD trigger. When a PR's Status is set to
# WIZ_BUILD_STATUS ("Functional Review", the human functional-QA stage), the
# poller auto-dispatches a tagged build ONCE (first time there is no claim).
# Later new commits do NOT auto-rebuild — the poller asks the PR author in the
# Slack review thread. Unlike the AI-review trigger, the status is NOT advanced.
# Idempotency: claim keyed on last successfully built head SHA; optional
# asked_sha/asked_at track a pending "want a rebuild?" so we only ask once per
# new head. Ack + result post to BOTH the Slack review thread AND a PR comment.
WIZ_BUILD_STATUS="Functional Review"

# Per-PR build-claim records (one JSON per repo/PR: head_sha = last built;
# asked_sha = pending rebuild question head, if any).
WIZ_BUILD_CLAIM_DIR="${HOME}/wizard/tmp/wiz-pr-build-claims"

# Board-driven APPROVAL auto-advance. When a PR sitting in one of the human
# review stages below gets a GitHub approval (>=1 APPROVED review from a NON-bot
# author, with no standing CHANGES_REQUESTED), the poller advances its board
# Status to WIZ_APPROVED_STATUS and notifies the author (in the existing Slack
# review thread if one exists, else a fresh root in the active channel).
#
# IMPORTANT: an approval happens on the PR, not the board, so it does NOT bump
# projectV2.updatedAt — the poller's cheap updatedAt skip-gate would miss it.
# The approval sweep therefore runs EVERY tick, independent of that gate.
#
# Idempotency: the status flip itself is the claim — once a PR moves to
# WIZ_APPROVED_STATUS it no longer matches the source statuses, so it can't
# re-fire (one notification per advance). '|'-separated list of source statuses.
WIZ_APPROVE_SOURCE_STATUSES="Functional Review|Code Review"
WIZ_APPROVED_STATUS="Ready to Merge"

# Poller bookkeeping: lock dir (prevents overlapping ticks) and the file storing
# the last-seen project updatedAt (cheap pre-scan gate — skip the item scan when
# the project hasn't changed since the previous tick).
WIZ_POLL_LOCK="${HOME}/wizard/tmp/wiz-pr-poll.lock"
WIZ_POLL_SEEN="${HOME}/wizard/tmp/wiz-pr-poll-seen.json"
WIZ_POLL_STALE_LOCK_SECS=600            # steal a lock older than this (crashed tick)

# Valid repos the pipeline reviews (space-separated; used by the poller to skip
# board items whose PR lives in some other repo).
WIZ_VALID_REPOS="wizard wizard-ai wizard-core wizard-release wizard-spec Qt-Advanced-Docking-System"

# wiz_pr_build_watch.sh tuning: poll interval, max wait, and how many times to
# retry locating the dispatched run before giving up.
WIZ_BUILD_POLL=30
WIZ_BUILD_MAX_WAIT=2400
WIZ_BUILD_FIND_TRIES=10

# GitHub-login -> Slack-user-ID lookup, used to @-mention human reviewers on
# build success/failure (and anywhere else we want to ping a GitHub user in
# Slack). Slack has no users:read.email scope here and GitHub reviewer emails
# are mostly private, so there is no reliable auto-mapping — this explicit table
# is the source of truth. Add a case when a new teammate starts reviewing. Bots
# (wiz-maestro, chatgpt-codex-connector) are intentionally absent so they're
# never mentioned; an unknown login echoes nothing (caller skips it).
#
# NOTE: a `case` function, NOT a `declare -A` map — macOS ships bash 3.2 which
# has no associative arrays.
wiz_gh_to_slack() {
    case "$1" in
        smills8)         echo "U0AJC0XPU06" ;;  # Sam Mills
        harry-wiz)       echo "U0AJ40ZG3DZ" ;;  # Harry Pal
        ksylvan)         echo "U0AJHGQK5PB" ;;  # Kayvan Sylvan
        aryankapoor2117) echo "U0AMQNUSNB1" ;;  # Aryan Kapoor
        carolalynn)      echo "U0AN454GG2J" ;;  # Carol Payne
        charisiii)       echo "U0BDBFNU0G1" ;;  # Charles Harris
        jbgardner7)      echo "U0AHY7U277D" ;;  # Jack Gardner
        *)               echo "" ;;
    esac
}
