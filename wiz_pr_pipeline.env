# wiz_pr_pipeline.env — shared config for the Wiz PR-review Slack pipeline.
#
# Sourced by wiz_pr_review.sh and wiz_pr_watch_finalize.sh.
# NOT secret (no tokens) — the Slack bot token is read from ~/.hermes/.env at
# runtime by the watcher.
#
# ----------------------------------------------------------------------------
# MODE / ACTIVE CHANNEL  (managed by wiz_pr_mode.sh — do not hand-edit)
# ----------------------------------------------------------------------------
# WIZ_ACTIVE_CHANNEL is the single channel the pipeline both MONITORS and posts
# ALL output to (threaded). Because the trigger channel and the output channel
# are the SAME, output can never leak into a different channel.
#
#   test mode -> #wiz-bot           (home/ops channel) C0BCCTG5F0R
#   prod mode -> #wiz-pull-requests (PR channel)       C0APAGTP97F
#
# Flip with:  ./wiz_pr_mode.sh test   |   ./wiz_pr_mode.sh prod
# (then restart the gateway so the trigger-channel config takes effect.)
WIZ_TEST_MODE=false
WIZ_ACTIVE_CHANNEL="C0APAGTP97F"

# Stable channel IDs (referenced by wiz_pr_mode.sh).
WIZ_HOME_CHANNEL="C0BCCTG5F0R"      # #wiz-bot
WIZ_PR_CHANNEL="C0APAGTP97F"        # #wiz-pull-requests

# ----------------------------------------------------------------------------
# DEFAULTS
# ----------------------------------------------------------------------------
# Default Maestro agent type when the Slack message doesn't specify one.
WIZ_DEFAULT_AGENT_TYPE="claude-code"

# Files uploaded to the thread when a review finishes (relative to AUTORUN_FOLDER).
WIZ_REVIEW_FILES=(REVIEW_SCOPE.md CODE_ISSUES.md SECURITY_ISSUES.md TEST_GAPS.md REVIEW_SUMMARY.md)

# Finalize prompt sent to the Maestro agent after the review completes.
WIZ_FINALIZE_PROMPT="${HOME}/wizard/tmp/prompts/use-gh-cli-to-create-pr-review-from-summary-finalize.md"

# maestro_watch.sh tuning (grace seconds, poll seconds).
WIZ_WATCH_GRACE=90
WIZ_WATCH_POLL=10

# Reaction emoji names (no colons) used to annotate the triggering PR-link
# message: in-progress when the review starts, then swapped to done/failed.
WIZ_REACT_INPROGRESS="hourglass_flowing_sand"
WIZ_REACT_DONE="white_check_mark"
WIZ_REACT_FAILED="x"

# Directory for thread -> PR state records, keyed by Slack thread ts. Written by
# wiz_pr_review.sh on review 1, read back by wiz_pr_rereview.sh so a "re-review"
# reply (which carries no PR link) can recover the repo/PR/agent it belongs to.
WIZ_PR_STATE_DIR="${HOME}/wizard/tmp/wiz-pr-state"

# wiz_pr_build_watch.sh tuning: poll interval, max wait, and how many times to
# retry locating the dispatched run before giving up.
WIZ_BUILD_POLL=30
WIZ_BUILD_MAX_WAIT=2400
WIZ_BUILD_FIND_TRIES=10
